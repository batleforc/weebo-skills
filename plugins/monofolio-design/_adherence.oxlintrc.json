{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:JetBrains Mono|IBM Plex Sans))/i]",
        "message": "Font not provided by the design system. Available: JetBrains Mono, IBM Plex Sans."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--accent",
      "--accent-foreground",
      "--background",
      "--border",
      "--card",
      "--card-foreground",
      "--chart-1",
      "--chart-2",
      "--chart-3",
      "--chart-4",
      "--chart-5",
      "--container",
      "--cyber-glow",
      "--destructive",
      "--destructive-foreground",
      "--font-mono",
      "--font-sans",
      "--foreground",
      "--grid-line",
      "--input",
      "--muted",
      "--muted-foreground",
      "--popover",
      "--popover-foreground",
      "--primary",
      "--primary-foreground",
      "--radius",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--radius-xl",
      "--ring",
      "--secondary",
      "--secondary-foreground",
      "--space-1",
      "--space-16",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-5",
      "--space-6",
      "--space-8",
      "--steam-glow",
      "--text-2xs",
      "--text-base",
      "--text-h1",
      "--text-h2",
      "--text-h3",
      "--text-hero",
      "--text-hero-sm",
      "--text-sm",
      "--text-xs"
    ],
    "tokenKinds": {
      "--radius": "radius",
      "--radius-sm": "radius",
      "--radius-md": "radius",
      "--radius-lg": "radius",
      "--radius-xl": "radius",
      "--background": "color",
      "--foreground": "color",
      "--card": "color",
      "--card-foreground": "color",
      "--popover": "color",
      "--popover-foreground": "color",
      "--primary": "color",
      "--primary-foreground": "color",
      "--secondary": "color",
      "--secondary-foreground": "color",
      "--muted": "color",
      "--muted-foreground": "color",
      "--accent": "color",
      "--accent-foreground": "color",
      "--destructive": "color",
      "--destructive-foreground": "color",
      "--border": "color",
      "--input": "color",
      "--ring": "color",
      "--chart-1": "color",
      "--chart-2": "color",
      "--chart-3": "color",
      "--chart-4": "color",
      "--chart-5": "color",
      "--cyber-glow": "shadow",
      "--steam-glow": "shadow",
      "--grid-line": "color",
      "--font-sans": "font",
      "--font-mono": "font",
      "--text-hero": "font",
      "--text-hero-sm": "font",
      "--text-h1": "font",
      "--text-h2": "font",
      "--text-h3": "font",
      "--text-base": "font",
      "--text-sm": "font",
      "--text-xs": "font",
      "--text-2xs": "font",
      "--space-1": "spacing",
      "--space-2": "spacing",
      "--space-3": "spacing",
      "--space-4": "spacing",
      "--space-5": "spacing",
      "--space-6": "spacing",
      "--space-8": "spacing",
      "--space-16": "spacing",
      "--container": "spacing"
    },
